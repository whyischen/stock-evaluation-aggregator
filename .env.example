# SEA core
SEA_ENABLE_MOCK_PLUGINS=true
SEA_DB_PATH=/data/sea.sqlite3

# Live TradingAgents calls are disabled by default to avoid accidental LLM cost.
# Set to true only after installing the upstream TradingAgents project inside
# the plugin image/runtime and configuring an LLM provider.
SEA_ENABLE_LIVE_TRADINGAGENTS=false

# LLM provider credentials. Fill only the provider you plan to use.
# These legacy provider env vars are kept for availability checks and for
# upstream libraries that read credentials directly from the environment.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
QWEN_API_KEY=
GOOGLE_API_KEY=
DASHSCOPE_API_KEY=

# Optional local model endpoint.
OLLAMA_BASE_URL=

# TradingAgents upstream config passthrough.
# SEA passes these values into TradingAgentsGraph(config=...) without
# interpreting provider-specific fields. Use either JSON objects:
# SEA_TRADINGAGENTS_CONFIG_JSON={"llm_provider":"openai","backend_url":"https://api.openai.com/v1","deep_think_llm":"gpt-4.1","quick_think_llm":"gpt-4.1-mini"}
# SEA_TRADINGAGENTS_CN_CONFIG_JSON={"quick_provider":"dashscope","deep_provider":"dashscope","quick_api_key":"...","deep_api_key":"..."}
SEA_TRADINGAGENTS_ALL_CONFIG_JSON=
SEA_TRADINGAGENTS_CONFIG_JSON=
SEA_TRADINGAGENTS_CN_CONFIG_JSON=

# Or double-underscore keys, which map to lowercase config keys:
SEA_TRADINGAGENTS_CONFIG__LLM_PROVIDER=
SEA_TRADINGAGENTS_CONFIG__BACKEND_URL=
SEA_TRADINGAGENTS_CONFIG__DEEP_THINK_LLM=
SEA_TRADINGAGENTS_CONFIG__QUICK_THINK_LLM=
SEA_TRADINGAGENTS_CN_CONFIG__QUICK_PROVIDER=
SEA_TRADINGAGENTS_CN_CONFIG__DEEP_PROVIDER=
SEA_TRADINGAGENTS_CN_CONFIG__QUICK_API_KEY=
SEA_TRADINGAGENTS_CN_CONFIG__DEEP_API_KEY=
SEA_TRADINGAGENTS_CN_CONFIG__QUICK_MODEL=
SEA_TRADINGAGENTS_CN_CONFIG__DEEP_MODEL=

# Plugin service tuning
SEA_TRADINGAGENTS_CN_TIMEOUT_SECONDS=300
SEA_TRADINGAGENTS_TIMEOUT_SECONDS=300
SEA_TRADINGAGENTS_CN_WEIGHT=1.0
SEA_TRADINGAGENTS_WEIGHT=1.0
