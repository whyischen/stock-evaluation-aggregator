ARG PYTHON_BASE_IMAGE=docker.m.daocloud.io/library/python:3.12-slim
FROM ${PYTHON_BASE_IMAGE}

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
ENV PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn

WORKDIR /app

COPY pyproject.toml README.md ./
COPY sea_core ./sea_core
COPY sea_api ./sea_api
COPY plugins ./plugins
COPY web ./web

RUN pip install --no-cache-dir . tradingagents==0.7.0

EXPOSE 8080

CMD ["uvicorn", "plugins.service:app", "--host", "0.0.0.0", "--port", "8080"]
